@page
@model MMLHub.Web.Pages.JobLogModel

<div class="hub-card">
    <h1>Log Job</h1>

    <form id="jobForm">
        <input name="Reference" placeholder="Reference" required />
        <select name="ClientId">
            <option value="1">Client A</option>
            <option value="2">Client B</option>
        </select>
        <input name="SiteName" placeholder="Site" required />

        <textarea name="Description" placeholder="Description"></textarea>

        <select name="Status">
            <option>Open</option>
            <option>In Progress</option>
            <option>Closed</option>
        </select>

        <button type="submit">Submit</button>
    </form>

    <p id="result"></p>
</div>

@section Scripts {
<script>
    const form = document.getElementById('jobForm');
    const result = document.getElementById('result');
    const button = form.querySelector('button');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        button.disabled = true;
        button.innerText = "Submitting...";

        const data = Object.fromEntries(new FormData(form));

        try {
            const response = await fetch('/api/jobs', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const res = await response.json();

            result.innerText = res.message;

            // ✅ Clear form
            form.reset();

        } catch (err) {
            result.innerText = "Error submitting job";
        }

        button.disabled = false;
        button.innerText = "Submit";
    });
</script>
}