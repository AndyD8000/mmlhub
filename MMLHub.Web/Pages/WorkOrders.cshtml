@page
@model MMLHub.Web.Pages.WorkOrdersModel

<div class="hub-card">
    <h1>Work Orders</h1>

    <!-- Summary -->
    <div class="hub-grid">
        <div class="hub-card">Total: @Model.Total</div>
        <div class="hub-card">Open: @Model.Open</div>
        <div class="hub-card">In Progress: @Model.InProgress</div>
        <div class="hub-card">Closed: @Model.Closed</div>
    </div>

    <!-- Filters -->
    <form method="get" style="margin-top:20px;">
        <input type="text" name="Search" placeholder="Search..." value="@Model.Search" />

        <select name="Status">
            <option value="">All</option>
            <option value="Open">Open</option>
            <option value="In Progress">In Progress</option>
            <option value="Closed">Closed</option>
        </select>

        <button type="submit">Filter</button>
    </form>

    <!-- Table -->
    <table>
        <thead>
            <tr>
                <th>Reference</th>
                <th>Client</th>
                <th>Site</th>
                <th>Description</th>
                <th>Status</th>
                <th>Logged</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.WorkOrders)
            {
                <tr>
                    <td>@order.Reference</td>
                    <td>@order.ClientName</td>
                    <td>@order.SiteName</td>
                    <td>@order.Description</td>
                    <td>@order.Status</td>
                    <td>@order.LoggedDate.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>